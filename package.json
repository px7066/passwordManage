{
  "name": "server-password-manager",
  "version": "1.0.0-beta.1",
  "description": "服务器密码管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "password",
    "manager",
    "electron"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "node-pty": "^1.1.0",
    "ssh2": "^1.17.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "xterm": "^5.3.0"
  },
  "build": {
    "appId": "com.spm.app",
    "productName": "Server Password Manager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    }
  }
}
